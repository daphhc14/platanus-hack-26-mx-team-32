{
  "manifest_version": 2,
  "name": "Hilo Capturador — Fosas y Desapariciones",
  "version": "0.1.0",
  "description": "Captura pasiva de posts sobre fosas y desapariciones en grupos de Facebook. PII redactada en tiempo real. Para investigación de derechos humanos.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "notifications"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/groups/*",
        "https://mbasic.facebook.com/groups/*",
        "https://m.facebook.com/groups/*"
      ],
      "js": ["detector.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Hilo Capturador"
  },

  "web_accessible_resources": [
    "overlay.css"
  ]
}
