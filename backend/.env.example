# Supabase — server-side config for the backend.
# Reads work with the publishable (anon) key; switch to the service_role key
# only when we add writes that RLS would block.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<publishable-or-service-role-key>

# CORS — the Vite frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Firecrawl — web/news search for victim cases.
# https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...
