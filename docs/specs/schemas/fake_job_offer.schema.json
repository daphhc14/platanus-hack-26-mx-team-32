{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hilo.fake_job_offer.v1",
  "title": "FakeJobOfferExtraction",
  "type": "object",
  "required": ["is_job_offer", "risk_signals", "confidence", "privacy_level"],
  "additionalProperties": false,
  "properties": {
    "is_job_offer": { "type": "boolean" },
    "job_title": { "type": "string" },
    "salary_text": { "type": "string" },
    "location_text": { "type": "string" },
    "contact_methods": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_signals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "possible_mechanism": { "type": "string" },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "privacy_level": {
      "type": "string",
      "enum": ["internal", "restricted"]
    },
    "needs_human_review": { "type": "boolean" },
    "notes": { "type": "string" }
  }
}
