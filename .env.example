# ── Facebook Scraper ──
# REQUIRED: Session cookies from an active Facebook login.
# How to get them:
#   1. Open Facebook in Firefox/Chrome, make sure you're logged in
#   2. Open DevTools (F12) → Application (or Storage) tab
#   3. Left sidebar → Cookies → https://www.facebook.com
#   4. Find "c_user" and "xs" — copy their Values here
#
# NOTE: These expire. If the scraper gets redirected to login,
#       re-extract fresh cookies from your browser.
FB_C_USER=
FB_XS=

# OPTIONAL: Only needed if you want auto-login when cookies expire.
# NOT used for scraping itself — cookies above are sufficient.
FB_EMAIL=
FB_PASSWORD=

# ── Supabase (for storing extracted fichas) ──
# Get from: Supabase dashboard → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJxxx...   # service_role key (for writing)
# SUPABASE_ANON_KEY=...  # anon key (for read-only queries from LangGraph)

# ── LLM (for ficha extraction with vision) ──
# Required: ONE of these for vision-based ficha extraction.
# The scraper-downloaded images go through this model to extract structured data.
#
# Recommended: claude-haiku-4-5 (cheapest with vision on Anthropic)
#  - $1/1M input, $5/1M output
#  - $40 ≈ 6,600 fichas
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-haiku-4-5
# LLM_MODEL=claude-sonnet-4-5     # if quality matters more than cost
# LLM_MODEL=gemini-2.0-flash      # if you have Google API (free tier available)

# ── Database ──
HILO_DB_PATH=
